{
  "name": "npm-shared",
  "type": "module",
  "private": true,
  "version": "1.0.0",
  "description": "Monorepo for my shared configuration NPM packages.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mareuter/npm-shared.git"
  },
  "scripts": {
    "dev": "turbo dev",
    "check": "turbo check",
    "build": "turbo build",
    "dry-run:npm": "turbo dry-run:npm",
    "format": "prettier --write .",
    "prepare": "husky",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "turbo": "^2.10.3"
  }
}
