{
  "name": "npm-shared",
  "type": "module",
  "private": true,
  "version": "1.0.0",
  "description": "Monorepo for my shared configuration NPM packages.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mareuter/npm-shared.git"
  },
  "scripts": {
    "dev": "turbo dev",
    "check": "turbo check",
    "build": "turbo build",
    "dry-run:npm": "turbo dry-run:npm",
    "format": "prettier --write .",
    "prepare": "husky",
    "changeset": "changeset",
    "cs:version": "changeset version"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6"
  }
}
