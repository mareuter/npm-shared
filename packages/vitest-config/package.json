{
  "name": "@mareuter/vitest-config",
  "version": "0.1.0",
  "type": "module",
  "description": "Vitest configuration for projects",
  "license": "MIT",
  "scripts": {
    "publish:npm": "npm publish --registry https://registry.npmjs.org/ --access public --ignore-scripts",
    "dry-run:npm": "npm publish --dry-run",
    "lint": "eslint . --max-warnings 0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mareuter/npm-shared.git"
  },
  "homepage": "https://github.com/mareuter/npm-shared/vitest-config#readme",
  "keywords": [
    "vitest",
    "vitestconfig"
  ],
  "author": {
    "name": "Michael Reuter"
  },
  "files": [
    "./configs/*.js",
    "index.js"
  ],
  "main": "index.js",
  "lint-staged": {
    "*.{json,md}": [
      "prettier --write"
    ],
    "**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mareuter/eslint-config": "workspace:*",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@vitest/ui": "4.1.8",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-prettier": "^5.5.6",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "@vitest/coverage-istanbul": "^4.1.8",
    "vitest": "^4.1.8"
  }
}
